{
  "name": "gpsaml",
  "version": "1.0.0",
  "main": "dist/index.js",
  "files": [
    "dist/**/*"
  ],
  "author": "Cooper",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./dist ./release",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "cp -r ./assets ./dist/",
    "start": "npm run build && electron dist",
    "dev": "tsc && electron dist",
    "package": "npm run build && electron-packager . gpsaml --platform=linux --arch=x64 --out=release --overwrite --prune=true",
    "package:win": "npm run build && electron-packager . gpsaml --platform=win32 --arch=x64 --out=release --overwrite --prune=true --no-deref-symlinks",
    "package:all": "npm run build && electron-packager . gpsaml --all --out=release --overwrite --prune=true",
    "prepare": "husky",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/xml2js": "^0.4.14",
    "@types/yargs": "^17.0.35",
    "electron": "^39.2.7",
    "electron-packager": "^17.1.2",
    "husky": "^9.1.7",
    "jshint": "^2.13.6",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/sudo-prompt": "^9.3.2",
    "got": "^11.8.6",
    "is-elevated": "^4.0.0",
    "loglevel": "^1.9.2",
    "xml2js": "^0.6.2",
    "yargs": "^18.0.0"
  }
}
